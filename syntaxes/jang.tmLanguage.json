{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "jang",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#types"
		},
		{
			"include": "#bools"
		}
		,
		{
			"include": "#variables"
		}
		,
		{
			"include": "#functions"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.jang",
				"match": "\\b(if|else|while|for|loop|fn|ret|mut|let)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.jang",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.jang",
					"match": "\\\\."
				}
			]
		},
		"comments": {
			"name": "comment.jang",
			"begin": "//",
			"end": "\n"
		},
		"numbers": {
			"name": "constant.numeric.jang",
			"match": "\\b\\d+(\\.\\d+)?\\b"
		},
		"types": {
			"patterns": [{
				"name": "storage.type.jang",
				"match": "\\b(i32|f32|i64|f64|bool)\\b"
			}]
		},
		"bools": {
			"patterns": [{
				"name": "constant.language.boolean.jang",
				"match": "\\b(true|false)\\b"
			}]
		},
		"variables": {
			"name": ".jang",
			"match": "\\b\\s+(\\.\\d+)?\\b"
		},
		"functions": {
			"name": "entity.name.function.jang",
			"end": "("
		}
	},
	"scopeName": "source.jang"
}