{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "jang",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#types"
		},
		{
			"include": "#bools"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.jang",
				"match": "\\b(if|else|while|for|fn|ret|loop|mut|let)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.jang",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.jang",
					"match": "\\\\."
				}
			]
		},
		"comments": {
			"name": "comment.jang",
			"begin": "//",
			"end": "\n"
		},
		"numbers": {
			"name": "number.jang",
			"begin": "//",
			"end": "\n",
			"patterns": [
				{
					"name": "constant.character.escape.jang",
					"match": "\\//\\."
				}
			]
		},
		"types": {
			"patterns": [{
				"name": "keyword.control.jang",
				"match": "\\b(i32|f32|i64|f64|bool)\\b"
			}]
		},
		"bools": {
			"patterns": [{
				"name": "bool.jang",
				"match": "\\b(true|false)\\b"
			}]
		}
	},
	"scopeName": "source.jang"
}